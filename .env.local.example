# Copy this file to .env.local and fill in the keys you have.
# The provider picker in the UI automatically disables any provider
# whose key is missing (see src/features/providers/registry.ts).

# Wired into the UI as disabled placeholders — see
# src/features/providers/stub-provider.ts for how to turn one on:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_ENDPOINT=
AZURE_OPENAI_API_KEY=

# MySQL data bank connection (read-only recommended: use a DB user with SELECT-only grants)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# SQL Server data bank connection (SQL Server authentication — not Windows/AD auth)
# Option A: a full connection string (takes priority if set)
MSSQL_CONNECTION_STRING=
# Option B: discrete fields, used if MSSQL_CONNECTION_STRING is empty
MSSQL_SERVER=
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=false

# Only needed if you've configured BOTH MySQL and SQL Server and want to force one: mysql | mssql
DB_ENGINE=