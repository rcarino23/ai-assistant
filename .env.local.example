# Copy this file to .env.local and fill in the keys you have.
# The provider picker in the UI automatically disables any provider
# whose key is missing (see src/features/providers/registry.ts).

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_ORG_ID=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local or self-hosted) — set to the server URL to enable, e.g.
# OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_ENDPOINT=

# Azure OpenAI — all three of these are required to enable the provider.
# AZURE_OPENAI_DEPLOYMENT is the deployment *name* you chose in the Azure
# portal (not the base model name) — that's what actually gets called.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01

# MySQL data bank connection (read-only recommended: use a DB user with SELECT-only grants)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# SQL Server data bank connection (SQL Server authentication — not Windows/AD auth)
# Option A: a full connection string (takes priority if set)
MSSQL_CONNECTION_STRING=
# Option B: discrete fields, used if MSSQL_CONNECTION_STRING is empty
MSSQL_SERVER=
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=false

# Only needed if you've configured BOTH MySQL and SQL Server and want to force one: mysql | mssql
DB_ENGINE=
